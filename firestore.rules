rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DEBUG ARENA SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, multi-tenant security model for a debugging competition. 
     * It relies on Path-Based Ownership for team data and Role-Based Access Control (RBAC) 
     * via an admin collection for administrative tasks.
     *
     * DATA STRUCTURE:
     * - /roles_admin/{adminId}: Marks users with administrative privileges.
     * - /teams/{teamId}: Root for all team-specific data (profiles, submissions, results).
     * - /competitionRounds/{roundId}: Public configuration for the competition rounds.
     * - /antiCheatingEvents/{eventId}: Logs for security monitoring.
     */

    // --- HELPER FUNCTIONS ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks ownership and ensures the document exists for update/delete operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Admin role markers. Only readable by admins.
     */
    match /roles_admin/{adminId} {
      allow get, list: if isSignedIn(); // Relaxed for prototype visibility
      allow create, update, delete: if false;
    }

    /**
     * @description Team profiles. 
     */
    match /teams/{teamId} {
      allow get: if isOwner(teamId) || isSignedIn(); // Relaxed for prototype visibility
      // Temporarily allow all signed-in users to list for the results page.
      // In production, this should be restricted to isAdmin() only.
      allow list: if isSignedIn(); 
      allow create: if isOwner(teamId) && request.resource.data.id == teamId;
      allow update: if (isExistingOwner(teamId) || isSignedIn()) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn(); // Relaxed for prototype 'Clear Leaderboard' button

      /**
       * @description MCQ Submissions nested under the team.
       */
      match /mcqSubmissions/{submissionId} {
        allow get, list: if isOwner(teamId) || isSignedIn();
        allow create: if isOwner(teamId) && request.resource.data.teamId == teamId;
        allow update: if (isExistingOwner(teamId) || isSignedIn()) && request.resource.data.teamId == resource.data.teamId;
        allow delete: if isSignedIn();
      }

      /**
       * @description Coding Submissions nested under the team.
       */
      match /codingSubmissions/{submissionId} {
        allow get, list: if isOwner(teamId) || isSignedIn();
        allow create: if isOwner(teamId) && request.resource.data.teamId == teamId;
        allow update: if (isExistingOwner(teamId) || isSignedIn()) && request.resource.data.teamId == resource.data.teamId;
        allow delete: if isSignedIn();

        /**
         * @description Detailed test case results.
         */
        match /testCaseResults/{resultId} {
          allow get, list: if isOwner(teamId) || isSignedIn();
          allow create, update, delete: if isSignedIn();
        }
      }
    }

    /**
     * @description Competition Round configuration.
     */
    match /competitionRounds/{roundId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Relaxed for prototype round management

      match /mcqQuestions/{mcqQuestionId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      match /mcqQuestionAnswers/{mcqQuestionId} {
        allow get, list, create, update, delete: if isSignedIn();
      }

      match /codingProblems/{codingProblemId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();

        match /testCases/{testCaseId} {
          allow get, list, create, update, delete: if isSignedIn();
        }
      }
    }

    /**
     * @description Logging of anti-cheating events.
     */
    match /antiCheatingEvents/{eventId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teamId == request.auth.uid;
      allow update, delete: if isSignedIn();
    }
  }
}